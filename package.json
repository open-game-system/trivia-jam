{
  "name": "@open-game-collective/trivia-jam",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "pnpm build && cp -f .dev.vars .output/server/.dev.vars 2>/dev/null; wrangler dev -c .output/server/wrangler.json --port 3000 --inspector-port 0",
    "preview": "pnpm build && wrangler dev -c .output/server/wrangler.json --port 3000 --inspector-port 0",
    "deploy": "pnpm build && wrangler deploy -c .output/server/wrangler.json",
    "typecheck": "tsc",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook"
  },
  "keywords": [
    "trivia"
  ],
  "author": "",
  "license": "ISC",
